<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#248FD8"
    android:padding="30dp"
    tools:context=".CadUser">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:src="@drawable/logo"
            android:contentDescription="Logo"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/borda_layout"
            android:padding="20dp"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cadastrar Pedido"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Código de Rastreio"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/edtCodigo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:padding="10dp"
                android:inputType="textPersonName"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Transportadora"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <Spinner
                android:id="@+id/spsTransportadora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/transportadora" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Serviço"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <Spinner
                android:id="@+id/spsServico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/servico_entrega" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <Spinner
                android:id="@+id/spsEstatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/status_entrega" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Origem"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/edtOrigem"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:padding="10dp"
                android:inputType="textPersonName"/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Destino"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/edtDestino"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:padding="10dp"
                android:inputType="textPersonName"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Previsão"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <Spinner
                android:id="@+id/spsPrevisao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/previsao" />

            <Button
                android:id="@+id/btRegistraPedido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Registrar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#298C1E"
                android:textStyle="bold"
                android:padding="12dp"/>

            <Button
                android:id="@+id/btAcompanha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Acompanhar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#298C1E"
                android:textStyle="bold"
                android:padding="12dp"/>

        </LinearLayout>
    </LinearLayout>

</ScrollView>
